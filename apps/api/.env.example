# Veritabanı
DATABASE_URL=postgresql://user:password@localhost:5432/fittrack

# JWT
JWT_ACCESS_SECRET=gizli-access-anahtar-buraya
JWT_REFRESH_SECRET=gizli-refresh-anahtar-buraya
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Sunucu
PORT=3001
NODE_ENV=development

# Cloudinary (görsel yükleme)
CLOUDINARY_CLOUD_NAME=cloud-name
CLOUDINARY_API_KEY=api-key
CLOUDINARY_API_SECRET=api-secret

# Redis (opsiyonel)
REDIS_URL=redis://localhost:6379

# Open Food Facts API
OPEN_FOOD_FACTS_TIMEOUT=3000
